{
  "mcpServers": {
    "task-master-ai": {
      "command": "npx",
      "args": [
        "-y",
        "task-master-ai"
      ],
      "env": {
        "TASK_MASTER_TOOLS": "all"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@context7/mcp@latest"
      ],
      "env": {
        "CONTEXT7_API_KEY": "ctx7sk-1d2887fd-f9dc-4f3f-a6fa-522f3bc38af9"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "openaiDeveloperDocs": {
      "url": "https://developers.openai.com/mcp"
    },
    "figma": {
      "url": "https://mcp.figma.com/mcp"
    }
  }
}
